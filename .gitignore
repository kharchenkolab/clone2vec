# --- Python Bytecode and Caches ---
# These are generated by the Python interpreter
__pycache__/
*.py[cod]
*$py.class

# Type checker cache
.mypy_cache/

# --- Virtual Environments ---
# Never commit your environment
venv/
env/
.venv/
.env/
virtualenv/

# --- Build and Distribution Artifacts ---
# These are generated when you package your library
build/
dist/
sdist/
*.egg-info/
.eggs/
*.whl
*.tar.gz

# setuptools cache
.setuptools-cache

# --- Testing and Coverage ---
# Caches and reports from testing tools
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
# tox environments
.tox/

# --- IDE and Editor Specific ---
# User-specific settings for various editors
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# --- Operating System Files ---
# Junk files from macOS, Windows, and Linux
.DS_Store
._*
Thumbs.db
ehthumbs.db

# --- Secrets and Local Config ---
# NEVER commit secrets, API keys, or local settings
.env
*.env
local_settings.py
config.local.ini

# --- Logs ---
*.log

# --- Docs Build Artifacts ---
docs/build/
docs/source/API/

# --- Jupyter Notebook Checkpoints ---
.ipynb_checkpoints/